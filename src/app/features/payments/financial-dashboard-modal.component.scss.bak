// ============================================================
// Financial Dashboard Modal - Compact SaaS-Style Design
// Production-grade styling matching NearBite theme
// ============================================================

@use '../../../styles/variables' as v;
@use '../../../styles/mixins' as *;

// Modal Backdrop & Container
.modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: v.v.$spacing-md;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

// Main Modal Container - Compact, professional
.modal-container {
  background: v.$bg-card;
  border: 1px solid v.$border-primary;
  border-radius: 12px;
  width: 100%;
  max-width: 1200px;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  box-shadow: v.$shadow-xl;
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(20px);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

// Modal Header - Minimal, functional
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: v.$spacing-md v.$spacing-lg;
  border-bottom: 1px solid v.$border-primary;
  flex-shrink: 0;
}

.modal-title {
  font-size: 1.125rem;
  font-weight: 600;
  color: v.$text-primary;
  margin: 0;
  letter-spacing: -0.01em;
}

.close-btn {
  background: transparent;
  border: none;
  color: v.$text-muted;
  cursor: pointer;
  padding: v.$spacing-xs;
  border-radius: 6px;
  transition: all 0.15s ease;
  display: flex;
  align-items: center;
  justify-content: center;

  &:hover {
    background: v.$bg-tertiary;
    color: v.$text-primary;
  }
}

// Modal Body - Scrollable content area
.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: v.$spacing-lg;
  position: relative;

  // Custom scrollbar
  &::-webkit-scrollbar {
    width: 8px;
  }

  &::-webkit-scrollbar-track {
    background: v.$bg-secondary;
  }

  &::-webkit-scrollbar-thumb {
    background: v.$border-secondary;
    border-radius: 4px;

    &:hover {
      background: v.$text-muted;
    }
  }
}

// Loading State
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 15, 15, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  border-radius: 8px;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 3px solid v.$border-secondary;
  border-top-color: v.$primary-light;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

// Section Spacing
section {
  margin-bottom: v.$spacing-lg;

  &:last-child {
    margin-bottom: 0;
  }
}

.section-title {
  font-size: 0.875rem;
  font-weight: 600;
  color: v.$text-secondary;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0 0 v.$spacing-md 0;
  display: flex;
  align-items: center;
  gap: v.$spacing-sm;

  .count {
    font-size: 0.75rem;
    color: v.$text-muted;
    font-weight: 400;
    text-transform: none;
  }
}

// ============================================================
// Section 1: Earnings Summary Cards
// ============================================================

.earnings-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: v.$spacing-md;
}

.stat-card {
  background: v.$bg-secondary;
  border: 1px solid v.$border-primary;
  border-radius: 8px;
  padding: v.$spacing-md;
  transition: all 0.2s ease;

  &:hover {
    background: v.$bg-card-hover;
    border-color: v.$border-secondary;
  }

  &.highlight {
    border-color: $accent-orange;
    background: linear-gradient(135deg, rgba(217, 118, 66, 0.08) 0%, rgba(217, 118, 66, 0.02) 100%);
  }
}

.stat-label {
  font-size: 0.75rem;
  color: v.$text-muted;
  margin-bottom: v.$spacing-xs;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

.stat-value {
  font-size: 1.5rem;
  font-weight: 700;
  color: v.$text-primary;
  letter-spacing: -0.02em;

  &.pending {
    color: $accent-orange;
  }
}

// ============================================================
// Section 2: Commission Breakdown
// ============================================================

.commission-grid {
  background: v.$bg-secondary;
  border: 1px solid v.$border-primary;
  border-radius: 8px;
  padding: v.$spacing-md;
  display: flex;
  flex-direction: column;
  gap: v.$spacing-sm;
}

.commission-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: v.$spacing-sm 0;
  font-size: 0.875rem;

  .label {
    color: v.$text-secondary;
    font-weight: 500;
  }

  .value {
    color: v.$text-primary;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  &.negative .value {
    color: v.$status-error;
  }

  &.total {
    border-top: 1px solid v.$border-secondary;
    padding-top: v.$spacing-md;
    margin-top: v.$spacing-xs;

    .label {
      color: v.$text-primary;
      font-weight: 600;
    }

    .value {
      color: v.$status-success;
      font-size: 1.125rem;
    }
  }

  &:not(.total) {
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);

    &:last-of-type {
      border-bottom: none;
    }
  }
}

// ============================================================
// Section 3: Status Indicators
// ============================================================

.status-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: v.$spacing-md;
}

.status-group {
  background: v.$bg-secondary;
  border: 1px solid v.$border-primary;
  border-radius: 8px;
  padding: v.$spacing-md;
}

.group-label {
  font-size: 0.75rem;
  color: v.$text-muted;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  margin-bottom: v.$spacing-sm;
}

.status-chips {
  display: flex;
  flex-wrap: wrap;
  gap: v.$spacing-sm;
}

.chip {
  display: flex;
  align-items: center;
  gap: v.$spacing-xs;
  padding: v.$spacing-xs v.$spacing-sm;
  border-radius: 6px;
  font-size: 0.75rem;
  font-weight: 500;
  border: 1px solid transparent;

  .chip-label {
    color: v.$text-secondary;
  }

  .chip-count {
    background: rgba(255, 255, 255, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }

  &.success, &.settled {
    background: rgba(46, 204, 113, 0.1);
    border-color: rgba(46, 204, 113, 0.2);
    .chip-label { color: v.$status-success; }
    .chip-count { color: v.$status-success; background: rgba(46, 204, 113, 0.15); }
  }

  &.pending, &.in-progress {
    background: rgba(243, 156, 18, 0.1);
    border-color: rgba(243, 156, 18, 0.2);
    .chip-label { color: v.$status-warning; }
    .chip-count { color: v.$status-warning; background: rgba(243, 156, 18, 0.15); }
  }

  &.failed {
    background: rgba(231, 76, 60, 0.1);
    border-color: rgba(231, 76, 60, 0.2);
    .chip-label { color: v.$status-error; }
    .chip-count { color: v.$status-error; background: rgba(231, 76, 60, 0.15); }
  }

  &.not-initiated {
    background: rgba(153, 153, 153, 0.1);
    border-color: rgba(153, 153, 153, 0.2);
    .chip-label { color: v.$text-muted; }
    .chip-count { color: v.$text-muted; background: rgba(153, 153, 153, 0.15); }
  }
}

// ============================================================
// Section 4: Filters & Export Controls
// ============================================================

.section-controls {
  background: v.$bg-secondary;
  border: 1px solid v.$border-primary;
  border-radius: 8px;
  padding: v.$spacing-md;
}

.controls-row {
  display: flex;
  flex-wrap: wrap;
  gap: v.$spacing-md;
  margin-bottom: v.$spacing-md;
  align-items: flex-end;
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: v.$spacing-xs;
  min-width: 140px;
}

.filter-label {
  font-size: 0.75rem;
  color: v.$text-muted;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

// Date Inputs
.date-inputs {
  display: flex;
  align-items: center;
  gap: v.$spacing-xs;
}

.date-input {
  background: v.$bg-tertiary;
  border: 1px solid v.$border-secondary;
  border-radius: 6px;
  padding: v.$spacing-xs v.$spacing-sm;
  color: v.$text-primary;
  font-size: 0.875rem;
  font-family: inherit;
  transition: all 0.15s ease;

  &:focus {
    outline: none;
    border-color: v.$primary-light;
    background: v.$bg-card;
  }

  &::-webkit-calendar-picker-indicator {
    filter: invert(0.7);
    cursor: pointer;
  }
}

.date-separator {
  color: v.$text-muted;
  font-size: 0.75rem;
}

// Dropdown Filters
.filter-dropdown {
  position: relative;
}

.filter-toggle {
  background: v.$bg-tertiary;
  border: 1px solid v.$border-secondary;
  border-radius: 6px;
  padding: v.$spacing-xs v.$spacing-sm;
  color: v.$text-primary;
  font-size: 0.875rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: v.$spacing-sm;
  min-width: 140px;
  transition: all 0.15s ease;

  &:hover {
    border-color: v.$border-focus;
    background: v.$bg-card;
  }

  .arrow {
    font-size: 0.625rem;
    color: v.$text-muted;
  }
}

.dropdown-menu {
  position: absolute;
  top: calc(100% + 4px);
  left: 0;
  background: v.$bg-tertiary;
  border: 1px solid v.$border-secondary;
  border-radius: 6px;
  padding: v.$spacing-xs;
  min-width: 180px;
  box-shadow: v.$shadow-lg;
  z-index: 100;
  animation: dropdownSlide 0.15s ease;
}

@keyframes dropdownSlide {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.dropdown-item {
  display: flex;
  align-items: center;
  gap: v.$spacing-sm;
  padding: v.$spacing-xs v.$spacing-sm;
  border-radius: 4px;
  cursor: pointer;
  font-size: 0.875rem;
  color: v.$text-secondary;
  transition: all 0.1s ease;

  &:hover {
    background: v.$bg-card-hover;
    color: v.$text-primary;
  }

  input[type="checkbox"] {
    pointer-events: none;
  }
}

// Buttons
.btn-secondary,
.btn-export {
  background: v.$bg-tertiary;
  border: 1px solid v.$border-secondary;
  border-radius: 6px;
  padding: v.$spacing-xs v.$spacing-md;
  color: v.$text-primary;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s ease;
  display: flex;
  align-items: center;
  gap: v.$spacing-xs;

  &:hover:not(:disabled) {
    background: v.$bg-card-hover;
    border-color: v.$primary-light;
    color: v.$text-primary;
  }

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  svg {
    width: 16px;
    height: 16px;
  }
}

.btn-secondary {
  margin-left: auto;
}

// Export Row
.export-row {
  display: flex;
  align-items: center;
  gap: v.$spacing-sm;
  padding-top: v.$spacing-md;
  border-top: 1px solid v.$border-primary;
}

.export-label {
  font-size: 0.875rem;
  color: v.$text-muted;
  margin-right: auto;
}

// ============================================================
// Section 5: Transaction History Table
// ============================================================

.table-wrapper {
  background: v.$bg-secondary;
  border: 1px solid v.$border-primary;
  border-radius: 8px;
  overflow: hidden;
}

.transactions-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;

  thead {
    background: v.$bg-tertiary;
    position: sticky;
    top: 0;
    z-index: 5;
  }

  th {
    padding: v.$spacing-sm v.$spacing-md;
    text-align: left;
    font-weight: 600;
    color: v.$text-muted;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    border-bottom: 1px solid v.$border-primary;
    white-space: nowrap;

    &.sortable {
      cursor: pointer;
      user-select: none;
      transition: color 0.15s ease;

      &:hover {
        color: v.$text-primary;
      }
    }

    &.amount {
      text-align: right;
    }
  }

  tbody tr {
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    transition: background 0.1s ease;

    &:hover {
      background: v.$bg-card-hover;
    }

    &:last-child {
      border-bottom: none;
    }
  }

  td {
    padding: v.$spacing-sm v.$spacing-md;
    color: v.$text-secondary;
    vertical-align: middle;

    &.date {
      font-size: 0.8125rem;
      color: v.$text-muted;
      font-variant-numeric: tabular-nums;
    }

    &.order-id {
      font-family: monospace;
      font-size: 0.8125rem;
      color: v.$text-primary;
    }

    &.method-badge {
      display: inline-block;
    }

    &.amount {
      text-align: right;
      font-variant-numeric: tabular-nums;
      font-weight: 600;
      color: v.$text-primary;

      &.negative {
        color: v.$status-error;
      }

      &.strong {
        color: v.$status-success;
      }
    }
  }
}

// Method Badge
.method-badge {
  display: inline-flex;
  padding: 2px 8px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid v.$border-secondary;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 500;
  color: v.$text-secondary;
}

// Status Badge
.status-badge {
  display: inline-flex;
  padding: 3px 8px;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 500;
  border: 1px solid transparent;

  &.status-success {
    background: rgba(46, 204, 113, 0.1);
    color: v.$status-success;
    border-color: rgba(46, 204, 113, 0.2);
  }

  &.status-pending, &.status-warning {
    background: rgba(243, 156, 18, 0.1);
    color: v.$status-warning;
    border-color: rgba(243, 156, 18, 0.2);
  }

  &.status-failed {
    background: rgba(231, 76, 60, 0.1);
    color: v.$status-error;
    border-color: rgba(231, 76, 60, 0.2);
  }

  &.status-muted {
    background: rgba(153, 153, 153, 0.1);
    color: v.$text-muted;
    border-color: rgba(153, 153, 153, 0.2);
  }
}

// Empty State
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: v.$spacing-xl * 2;
  color: v.$text-muted;

  svg {
    margin-bottom: v.$spacing-md;
    opacity: 0.3;
  }

  p {
    font-size: 0.875rem;
    margin: 0;
  }
}

// ============================================================
// Responsive Adjustments
// ============================================================

@media (max-width: 1024px) {
  .modal-container {
    max-width: 95vw;
  }

  .earnings-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .controls-row {
    flex-direction: column;
    align-items: stretch;

    .btn-secondary {
      margin-left: 0;
    }
  }

  .transactions-table {
    font-size: 0.8125rem;

    th, td {
      padding: v.$spacing-xs v.$spacing-sm;
    }
  }
}

@media (max-width: 768px) {
  .modal-backdrop {
    padding: 0;
    align-items: flex-start;
  }

  .modal-container {
    max-width: 100vw;
    max-height: 100vh;
    border-radius: 0;
  }

  .earnings-grid {
    grid-template-columns: 1fr;
  }

  .status-grid {
    grid-template-columns: 1fr;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .transactions-table {
    min-width: 900px;
  }
}
